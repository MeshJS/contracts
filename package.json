{
  "name": "@meshsdk/contract",
  "version": "1.9.0-beta.103",
  "description": "List of open-source smart contracts, complete with documentation, live demos, and end-to-end source code. https://meshjs.dev/smart-contracts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build:docs": "typedoc src/index.ts --json ../../apps/docs/src/data/mesh-contracts.json",
    "build": "tsup",
    "clean": "rm -rf .turbo && rm -rf dist && rm -rf node_modules",
    "dev": "tsup --watch",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "pack": "npm pack --pack-destination=./dist",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@meshsdk/core-cst": "^1.9.0-beta.102",
    "cbor": "^10.0.12"
  },
  "peerDependencies": {
    "@meshsdk/common": "^1.9.0-beta.102",
    "@meshsdk/core": "^1.9.0-beta.102"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "keywords": [
    "cardano",
    "ada",
    "web3",
    "blockchain",
    "sdk"
  ]
}
